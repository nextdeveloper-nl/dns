{
  "name": "nextdeveloper/dns",
  "description": "NextDeveloper DNS Package",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Harun Barış Bulut",
      "email": "baris.bulut@plusclouds.com"
    }
  ],
  "homepage": "https://github.com/nextdeveloper-nl/dns",
  "support": {
    "issues": "https://github.com/nextdeveloper-nl/dns/issues",
    "source": "https://github.com/nextdeveloper-nl/dns"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:nextdeveloper-nl/dns.git"
    }
  ],
  "require": {
    "php": ">=8.2.0",
    "league/fractal": "*",
    "monolog/monolog": "*",
    "basis-company/nats": "*"
  },
  "require-dev": {
    "illuminate/support": ">=8.0",
    "illuminate/database": ">=8.0",
    "illuminate/validation": ">=8.0",
    "guzzlehttp/guzzle": "*"
  },
  "autoload": {
    "psr-4": {
      "NextDeveloper\\DNS\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NextDeveloper\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "NextDeveloper\\DNS\\DNSServiceProvider"
      ]
    }
  },
  "suggest": {}
}
